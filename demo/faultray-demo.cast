[9.949676, "o", "  \u001b[1;33m100\u001b[0m\u001b[33m%\u001b[0m Agent \u001b[32m'Support AI Agent'\u001b[0m requires grounding data from \u001b[32m'PostgreSQL \u001b[0m\r\n\u001b[32m(\u001b[0m\u001b[32mprimary\u001b[0m\u001b[32m)\u001b[0m\u001b[32m'\u001b[0m \u001b[1m(\u001b[0mdatabase\u001b[1m)\u001b[0m. With data source DOWN, hallucination probability \u001b[1;35mH\u001b[0m\u001b[1m(\u001b[0ma,D,I\u001b[1m)\u001b[0m\r\n= \u001b[1;36m100\u001b[0m% \u001b[1m(\u001b[0mbase \u001b[33mh0\u001b[0m=\u001b[1;36m0\u001b[0m\u001b[1;36m.05\u001b[0m, weight \u001b[33mw\u001b[0m=\u001b[1;36m1\u001b[0m\u001b[1;36m.0\u001b[0m, \u001b[33mstatus\u001b[0m=\u001b[35mDOWN\u001b[0m\u001b[1m)\u001b[0m.\r\n"]
[9.950257, "o", "  \u001b[1;33m100\u001b[0m\u001b[33m%\u001b[0m Agent \u001b[32m'Support AI Agent'\u001b[0m requires grounding data from \u001b[32m'Redis \u001b[0m\u001b[32m(\u001b[0m\u001b[32mcache\u001b[0m\u001b[32m)\u001b[0m\u001b[32m'\u001b[0m \r\n\u001b[1m(\u001b[0mcache\u001b[1m)\u001b[0m. With data source DOWN, hallucination probability \u001b[1;35mH\u001b[0m\u001b[1m(\u001b[0ma,D,I\u001b[1m)\u001b[0m = \u001b[1;36m100\u001b[0m% \u001b[1m(\u001b[0mbase \r\n\u001b[33mh0\u001b[0m=\u001b[1;36m0\u001b[0m\u001b[1;36m.05\u001b[0m, weight \u001b[33mw\u001b[0m=\u001b[1;36m1\u001b[0m\u001b[1;36m.0\u001b[0m, \u001b[33mstatus\u001b[0m=\u001b[35mDOWN\u001b[0m\u001b[1m)\u001b[0m.\r\n"]

[9.679853, "o", "\u001b[3m    Infrastructure Overview    \u001b[0m\r\n┏━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━┓\r\n┃\u001b[1m \u001b[0m\u001b[1mMetric          \u001b[0m\u001b[1m \u001b[0m┃\u001b[1m \u001b[0m\u001b[1mValue   \u001b[0m\u001b[1m \u001b[0m┃\r\n┡━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━┩\r\n│\u001b[36m \u001b[0m\u001b[36mComponents      \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m9       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36mDependencies    \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m12      \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  load_balancer \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m1       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  app_server    \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m2       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  database      \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m1       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  cache         \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m1       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  queue         \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m1       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  ai_agent      \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m1       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  llm_endpoint  \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m1       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36m  tool_service  \u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[37m1       \u001b[0m\u001b[37m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36mResilience Score\u001b[0m\u001b[36m \u001b[0m│\u001b[37m \u001b[0m\u001b[31m40.5/100\u001b[0m\u001b[37m \u001b[0m│\r\n└──────────────────┴──────────┘\r\n"]
[9.680239, "o", "\r\n\u001b[36mRunning chaos simulation\u001b[0m\u001b[36m...\u001b[0m\r\n"]
[9.696876, "o", "\r\n"]
[9.698015, "o", "\u001b[31m╭─\u001b[0m\u001b[31m─────────────────────\u001b[0m\u001b[31m \u001b[0m\u001b[1;31mFaultRay Chaos Simulation Report\u001b[0m\u001b[31m \u001b[0m\u001b[31m─────────────────────\u001b[0m\u001b[31m─╮\u001b[0m\r\n\u001b[31m│\u001b[0m \u001b[1mResilience Score: \u001b[0m\u001b[1;31m40/100\u001b[0m                                                     \u001b[31m│\u001b[0m\r\n\u001b[31m│\u001b[0m                                                                              \u001b[31m│\u001b[0m\r\n\u001b[31m│\u001b[0m Scenarios tested: 255                                                        \u001b[31m│\u001b[0m\r\n\u001b[31m│\u001b[0m \u001b[1;31mCritical: 21\u001b[0m  \u001b[33mWarning: 84\u001b[0m  \u001b[32mPassed: 150\u001b[0m                                       \u001b[31m│\u001b[0m\r\n\u001b[31m╰──────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[9.69819, "o", "\r\n"]
[9.698728, "o", "\u001b[1;31mCRITICAL FINDINGS\u001b[0m\r\n"]
[9.698832, "o", "\r\n"]
[9.699137, "o", "  \u001b[1;31m10.0\u001b[0m\u001b[1;31m/\u001b[0m\u001b[1;31m10\u001b[0m\u001b[1;31m CRITICAL\u001b[0m  Traffic spike \u001b[1m(\u001b[0m1\u001b[1;36m0x\u001b[0m\u001b[1m)\u001b[0m\r\n"]
[9.699405, "o", "    Traffic DDoS-level \u001b[1m(\u001b[0m1\u001b[1;36m0x\u001b[0m normal\u001b[1m)\u001b[0m across all entry points\r\n"]
[9.701069, "o", "  \u001b[2mCascade path:\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m nginx (LB)\r\n│         \u001b[2mCapacity exceeded: 450% (max 100%)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m api-server-1\r\n│         \u001b[2mCapacity exceeded: 900% (max 100%)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m api-server-2\r\n│         \u001b[2mCapacity exceeded: 840% (max 100%)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m PostgreSQL (primary)\r\n│         \u001b[2mCapacity exceeded: 900% (max 100%)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m Redis (cache)\r\n│         \u001b[2mCapacity exceeded: 600% (max 100%)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m RabbitMQ\r\n│         \u001b[2mCapacity exceeded: 400% (max 100%)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m Support AI Agent\r\n│         \u001b[2mCapacity exceeded: 550% (max 100%)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m Claude API Endpoint\r\n│         \u001b[2mCapacity exceeded: 450% (max 100%)\u001b[0m\r\n└── \u001b[1;31mDOWN\u001b[0m DB Query Tool\r\n          \u001b[2mCapacity exceeded: 300% (max 100%)\u001b[0m\r\n\r\n"]
[9.701415, "o", "  \u001b[1;31m8.0\u001b[0m\u001b[1;31m/\u001b[0m\u001b[1;31m10\u001b[0m\u001b[1;31m CRITICAL\u001b[0m  Triple failure: nginx + app-\u001b[1;36m1\u001b[0m + postgres\r\n"]
[9.701557, "o", "    Simultaneous failure of nginx + app-\u001b[1;36m1\u001b[0m + postgres\r\n"]
[9.703308, "o", "  \u001b[2mCascade path:\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m nginx (LB)\r\n│         \u001b[2mComponent failure (simulated)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m api-server-1\r\n│         \u001b[2mComponent failure (simulated)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m nginx (LB) \u001b[2m(+30s)\u001b[0m\r\n│         \u001b[2mDependency api-server-1 is down, no alternative path. Timeout after \u001b[0m\r\n│   \u001b[2m30s, retry storm expected (90s)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m PostgreSQL (primary)\r\n│         \u001b[2mComponent failure (simulated)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m DB Query Tool \u001b[2m(+0s)\u001b[0m\r\n│         \u001b[2mDependency PostgreSQL (primary) is down, no alternative path. Timeout \u001b[0m\r\n│   \u001b[2mafter 30s, retry storm expected (90s)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m Support AI Agent \u001b[2m(+30s)\u001b[0m\r\n│         \u001b[2mDependency DB Query Tool is down, no alternative path. Timeout after \u001b[0m\r\n│   \u001b[2m30s, retry storm expected (90s)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m api-server-1 \u001b[2m(+-30s)\u001b[0m\r\n│         \u001b[2mDependency PostgreSQL (primary) is down, no alternative path. Timeout \u001b[0m\r\n│   \u001b[2mafter 30s, retry storm expected (90s)\u001b[0m\r\n├── \u001b[1;31mDOWN\u001b[0m nginx (LB) \u001b[2m(+30s)\u001b[0m\r\n│         \u001b[2mDependency api-server-1 is down, no alternative path. Timeout after \u001b[0m\r\n│   \u001b[2m30s, retry storm expected (90s)\u001b[0m\r\n└── \u001b[1;31mDOWN\u001b[0m api-server-2 \u001b[2m(+-30s)\u001b[0m\r\n          \u001b[2mDependency PostgreSQL (primary) is down, no alternative path. Timeout \u001b[0m\r\n    \u001b[2mafter 30s, retry storm expected (90s)\u001b[0m\r\n"]
